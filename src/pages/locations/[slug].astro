---
import Layout from "../../layouts/Layout.astro";
import SidebarCTA from "../../components/SidebarCTA.astro";
import { BUSINESS_NAME, PHONE_RAW, SITE_URL } from "../../config/site";
import { createServerClient } from "../../lib/supabase";
import type { LocationRow, ServiceRow } from "../../types/database";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/404");
const supabase = createServerClient();

const [locationResult, servicesResult] = await Promise.all([
  supabase.from("locations").select("*").eq("slug", slug).eq("is_active", true).single(),
  supabase.from("services").select("slug, name, description").eq("is_active", true).order("sort_order"),
]);

if (locationResult.error || !locationResult.data) return Astro.redirect("/404");

const location = locationResult.data as LocationRow;
const services = (servicesResult.data ?? []) as Pick<ServiceRow, "slug" | "name" | "description">[];
const canonicalUrl = `${Astro.site?.toString().replace(/\/$/, "")}/locations/${location.slug}`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home",      item: `${SITE_URL}/` },
    { "@type": "ListItem", position: 2, name: "Locations", item: `${SITE_URL}/locations` },
    { "@type": "ListItem", position: 3, name: `${location.city}, ${location.state}` },
  ],
};
---

<Layout
  title={location.seo_title || `${location.city}, ${location.state}`}
  description={location.meta_description}
>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Header />

  <!-- Hero -->
  <section class="section-padding bg-brand-secondary text-white">
    <div class="site-container">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-1.5 text-[13px] mb-5" aria-label="Breadcrumb">
        <a href="/" class="text-white/60 hover:text-white transition-colors">Home</a>
        <span class="text-white/30" aria-hidden="true">/</span>
        <a href="/locations" class="text-white/60 hover:text-white transition-colors">Locations</a>
        <span class="text-white/30" aria-hidden="true">/</span>
        <span class="text-white/90">{location.city}, {location.state}</span>
      </nav>
      <span class="section-label-light">Service Area</span>
      <h1 class="section-heading-white reveal-up">{location.h1 || `${BUSINESS_NAME} in ${location.city}`}</h1>
      <div class="accent-divider" style="background: var(--brand-accent);" />
      <p class="section-subheading text-white/80 reveal-up">{location.meta_description}</p>
      <div class="mt-8 flex gap-4 flex-wrap reveal-up">
        <button
          type="button"
          data-quote-modal
          class="btn-primary"
        >
          Get a Free Quote in {location.city}
        </button>
        <a href={`tel:${PHONE_RAW}`} class="btn-ghost">Call Now</a>
      </div>
    </div>
  </section>

  <!-- Body: two-column grid on lg+ -->
  <section class="section-padding bg-snow">
    <div class="site-container">
      <div class="grid lg:grid-cols-[1fr_300px] gap-12 items-start">

        <!-- Main content -->
        <div>
          {location.body_html && (
            <div class="prose prose-lg max-w-none">
              <Fragment set:html={location.body_html} />
            </div>
          )}

          <!-- Services grid -->
          {services.length > 0 && (
            <div class="mt-12">
              <span class="section-label">What We Do</span>
              <h2 class="section-heading reveal-up">Services in {location.city}</h2>
              <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
                {services.map((s) => (
                  <a href={`/services/${s.slug}`} class="reveal-up block p-5 bg-white rounded-xl border border-border hover:shadow-md transition-shadow">
                    <h3 class="font-display font-700 text-ink">{s.name}</h3>
                    <p class="mt-1.5 text-sm text-muted">{s.description}</p>
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- FAQs -->
          {location.faq_items.length > 0 && (
            <div class="mt-12">
              <h2 class="section-heading reveal-up">FAQs for {location.city}</h2>
              <div class="mt-8 space-y-4">
                {location.faq_items.map((faq) => (
                  <details class="reveal-up border border-border rounded-xl p-6 bg-white">
                    <summary class="font-display font-700 text-ink cursor-pointer">{faq.question}</summary>
                    <p class="mt-4 text-muted">{faq.answer}</p>
                  </details>
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Sticky sidebar — desktop only, no service pre-selection on location pages -->
        <SidebarCTA />

      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll<HTMLElement>(".reveal-up").forEach((el) => {
    gsap.fromTo(el, { opacity: 0, y: 24 }, {
      opacity: 1, y: 0, duration: 0.4, ease: "power2.out",
      scrollTrigger: { trigger: el, start: "top 88%", once: true },
    });
  });
</script>
