const { slug } = Astro.params;
const service = allServices.find((s) => s.slug === slug);
if (!service) return Astro.redirect("/404");

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE_URL}/` },
    { "@type": "ListItem", "position": 2, "name": "Services", "item": `${SITE_URL}/services` },
    { "@type": "ListItem", "position": 3, "name": service.title, "item": `${SITE_URL}/services/${service.slug}` }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": service.title,
  "provider": { "@id": `${SITE_URL}/#business` },
  "areaServed": { "@type": "City", "name": PRIMARY_CITY, "addressRegion": PRIMARY_STATE },
  "description": service.intro
};

const faqSchema = service.faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": service.faqs.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": { "@type": "Answer", "text": a }
  }))
} : null;

// HowTo schema — maps to the 4-step "Our Seamless Process" section.
// Used by Google for rich results and AI Overviews (GEO signal).
const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": `How to Get ${service.title} in ${PRIMARY_CITY}, ${PRIMARY_STATE}`,
  "description": `The simple 4-step process to book ${service.title.toLowerCase()} with ${BUSINESS_NAME} in ${PRIMARY_CITY}, TX.`,
  "totalTime": "PT30M",
  "estimatedCost": {
    "@type": "MonetaryAmount",
    "currency": "USD",
    "value": "Free estimate"
  },
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "Request a Quote",
      "text": "Tell us what you need via our online form or by phone. We respond within 60 minutes during business hours.",
      "url": `${SITE_URL}/contact`
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "Transparent Pricing",
      "text": "Receive a clear, upfront price before any work begins. No hidden fees, no surprise invoices."
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Expert Repair",
      "text": "A background-checked, fully insured technician arrives on time wearing shoe covers and ready to work."
    },
    {
      "@type": "HowToStep",
      "position": 4,
      "name": "Clean Home",
      "text": "We clean up completely before we leave — floors protected, debris removed, your home left spotless."
    }
  ]
};

// Article schema — injected only on pages with SEO article content (e.g. drywall-repair).
// Primary GEO signal: tells AI systems (ChatGPT, Perplexity, Google AI Overviews)
// this is authoritative editorial content about the topic.
const articleSchema = service.seoContent ? {
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": `${SITE_URL}/services/${service.slug}#article`,
  "headline": service.title,
  "description": service.metaDesc,
  "datePublished": "2026-03-27",
  "dateModified": new Date().toISOString().split('T')[0],
  "author": {
    "@type": "Organization",
    "name": BUSINESS_NAME,
    "url": SITE_URL
  },
  "publisher": {
    "@type": "Organization",
    "name": BUSINESS_NAME,
    "url": SITE_URL,
    "logo": {
      "@type": "ImageObject",
      "url": `${SITE_URL}/logo-horizontal-dark.webp`
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${SITE_URL}/services/${service.slug}`
  },
  "about": {
    "@type": "Service",
    "name": service.title,
    "provider": { "@id": `${SITE_URL}/#business` },
    "areaServed": { "@type": "City", "name": PRIMARY_CITY, "addressRegion": PRIMARY_STATE }
  },
  "image": {
    "@type": "ImageObject",
    "url": `${SITE_URL}${service.image}`,
    "width": 600,
    "height": 400
  },
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": [".hero-speakable", ".overview-speakable"]
  }
} : null;

const pageSchemas = [breadcrumbSchema, serviceSchema, howToSchema];
if (faqSchema) pageSchemas.push(faqSchema);
if (articleSchema) pageSchemas.push(articleSchema);
---

<Layout
  title={(service.slug === 'drywall-repair' || service.slug === 'tv-mounting') ? service.title : `${service.title} in ${PRIMARY_CITY}, ${PRIMARY_STATE} | ${BUSINESS_NAME}`}
  description={service.metaDesc}
  ogImage={service.image}
  schema={pageSchemas}
>
  <Header />

  <!-- ── Photo Hero ─────────────────────────────────────────────────────── -->
  <section class="relative min-h-[420px] lg:min-h-[500px] flex items-end overflow-hidden">
    <!-- Service photo background -->
    <div class="absolute inset-0 z-0">
      <img
        src={service.image}
        alt={`${service.title} service in ${PRIMARY_CITY} TX`}
        class="w-full h-full object-cover object-[55%_top]"
        loading="eager"
        fetchpriority="high"
        width="600"
        height="400"
        srcset={`${service.image.replace('.webp', '-400w.webp')} 400w, ${service.image.replace('.webp', '-600w.webp')} 600w, ${service.image.replace('.webp', '-800w.webp')} 800w`}
        sizes="100vw"
      />
      <!-- Gradient overlay — dark at bottom for text legibility -->
      <div class="absolute inset-0 bg-gradient-to-t from-[#151d25]/98 via-[#151d25]/70 to-[#151d25]/30"></div>
    </div>

    <!-- Hero content -->
    <div class="relative z-10 w-full site-container pb-16 lg:pb-20 pt-32 hero-speakable">
      <!-- Breadcrumb -->
      <div class="flex items-center gap-2 text-[13px] text-white/70 mb-5">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <a href="/services" class="hover:text-white transition-colors">Services</a>
        <span>/</span>
        <span class="text-white/90">{service.title}</span>
      </div>
      <p class="section-label">{BUSINESS_NAME}</p>
      <h1 class="text-white font-black tracking-tight leading-[1.05] mb-5 max-w-[720px]" style="font-size: clamp(2rem, 4vw, 3.25rem);">
        {service.hero}
      </h1>
      <p class="text-white/90 text-[17px] max-w-[580px] leading-relaxed mb-8">
        {service.intro}
      </p>
      <div class="flex flex-wrap gap-4">
        <a href={telHref} class="btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.13 6.13l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.73 2.03z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Get a Free Estimate
        </a>
        <a href="/contact" class="btn-ghost">
          Request Online
        </a>
      </div>
    </div>
  </section>

  <!-- ── What's Included ────────────────────────────────────────────────── -->
  <section class="bg-[#f0f2f4] section-padding">
    <div class="site-container">
      <div class="text-center section-header">
        <p class="section-label">What's Included</p>
        <h2 class="section-heading">{service.title} — Full Service</h2>
        <div class="accent-divider-center"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 lg:gap-8 max-w-[960px] mx-auto">
        {service.subServices.map(({ title, desc }) => (
          <div class="bg-white rounded-2xl p-8 border border-[#cdd8e3] hover:shadow-lg hover:border-[#2c3e50] transition-all duration-300">
            <div class="flex items-start gap-4">
              <div class="mt-0.5 w-8 h-8 shrink-0 rounded-full bg-[#b05d45] flex items-center justify-center shadow-md">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                  <polyline points="20 6 9 17 4 12" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <h3 class="text-[#151d25] text-[18px] font-bold mb-2">{title}</h3>
                <p class="text-[#567798] text-[15px] leading-relaxed">{desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Process ────────────────────────────────────────────────────────── -->
  <section class="bg-white section-padding">
    <div class="site-container">
      <div class="text-center section-header">
        <p class="section-label">How It Works</p>
        <h2 class="section-heading">Our Seamless Process</h2>
        <div class="accent-divider-center"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
        {[
          { num: "01", title: "Request a Quote",     desc: "Tell us what you need via form or phone." },
          { num: "02", title: "Transparent Pricing", desc: "Know the exact cost before we start." },
          { num: "03", title: "Expert Repair",       desc: "Background-checked pros arrive on time." },
          { num: "04", title: "Clean Home",          desc: "We clean up completely before we leave." },
        ].map(({ num, title, desc }) => (
          <div class="flex flex-col items-center text-center gap-5">
            <div class="w-20 h-20 rounded-full bg-[#2c3e50] flex items-center justify-center shadow-lg">
              <span class="text-white text-[22px] font-black">{num}</span>
            </div>
            <h3 class="text-[#151d25] text-[17px] font-bold">{title}</h3>
            <p class="text-[#567798] text-[15px] leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── SEO Article Content (service-specific, e.g. drywall-repair) ────────── -->
  {service.seoContent && (
    <>
      {/* Overview + Key Highlights */}
      <section class="bg-[#f0f2f4] section-padding">
        <div class="site-container">
          <div class="grid lg:grid-cols-[1fr_380px] gap-12 lg:gap-16 items-start overview-speakable">
            <div>
              <p class="section-label">Brief Overview</p>
              <h2 class="section-heading mb-6">About Our Drywall Repair Services</h2>
              <div class="accent-divider"></div>
              <p class="text-[#151d25] text-[17px] leading-relaxed mt-6">{service.seoContent.overview}</p>
            </div>
            <div class="bg-white rounded-2xl border border-[#cdd8e3] p-8 shadow-sm">
              <p class="section-label mb-4">Key Highlights</p>
              <ul class="flex flex-col gap-4">
                {service.seoContent.highlights.map((item) => (
                  <li class="flex items-start gap-3">
                    <div class="mt-1 w-5 h-5 shrink-0 rounded-full bg-[#b05d45] flex items-center justify-center shadow-sm">
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none">
                        <polyline points="20 6 9 17 4 12" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                    <span class="text-[#151d25] text-[15px] leading-relaxed">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>

      {/* Choosing the Right Contractor + Comparison Table */}
      <section class="bg-white section-padding">
        <div class="site-container">
          <p class="section-label">How to Choose</p>
          <h2 class="section-heading mb-6">{service.seoContent.contractorSection.heading}</h2>
          <div class="accent-divider"></div>
          <p class="text-[#151d25] text-[17px] leading-relaxed mt-6 max-w-[760px] mb-10">{service.seoContent.contractorSection.body}</p>
          <div class="overflow-x-auto rounded-2xl border border-[#cdd8e3] shadow-sm">
            <table class="w-full text-left">
              <thead class="bg-[#2c3e50] text-white">
                <tr>
                  <th class="px-6 py-4 text-[14px] font-bold uppercase tracking-wide">Criteria</th>
                  <th class="px-6 py-4 text-[14px] font-bold uppercase tracking-wide">Description</th>
                  <th class="px-6 py-4 text-[14px] font-bold uppercase tracking-wide">Benefit</th>
                  <th class="px-6 py-4 text-[14px] font-bold uppercase tracking-wide">Outcome</th>
                </tr>
              </thead>
              <tbody>
                {service.seoContent.contractorSection.tableRows.map((row, i) => (
                  <tr class={i % 2 === 0 ? "bg-white" : "bg-[#f8f9fa]"}>
                    <td class="px-6 py-4 text-[15px] font-semibold text-[#151d25]">{row.criteria}</td>
                    <td class="px-6 py-4 text-[15px] text-[#567798]">{row.description}</td>
                    <td class="px-6 py-4 text-[15px] text-[#567798]">{row.benefit}</td>
                    <td class="px-6 py-4 text-[15px] text-[#567798]">{row.outcome}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="text-[#567798] text-[13px] italic mt-3">Key factors to consider when selecting a drywall repair contractor, emphasizing alignment of service quality with homeowner expectations.</p>
        </div>
      </section>

      {/* Comprehensive Services */}
      <section class="bg-[#f0f2f4] section-padding">
        <div class="site-container">
          <p class="section-label">Full Service Range</p>
          <h2 class="section-heading mb-6">{service.seoContent.comprehensiveSection.heading}</h2>
          <div class="accent-divider"></div>
          <p class="text-[#151d25] text-[17px] leading-relaxed mt-6 max-w-[760px]">{service.seoContent.comprehensiveSection.body}</p>
        </div>
      </section>

      {/* Transparency + Services Table */}
      <section class="bg-white section-padding">
        <div class="site-container">
          <p class="section-label">Our Promise</p>
          <h2 class="section-heading mb-6">{service.seoContent.transparencySection.heading}</h2>
          <div class="accent-divider"></div>
          <p class="text-[#151d25] text-[17px] leading-relaxed mt-6 max-w-[760px] mb-10">{service.seoContent.transparencySection.body}</p>
          <div class="overflow-x-auto rounded-2xl border border-[#cdd8e3] shadow-sm">
            <table class="w-full text-left">
              <thead class="bg-[#2c3e50] text-white">
                <tr>
                  <th class="px-6 py-4 text-[14px] font-bold uppercase tracking-wide">Service Offered</th>
                  <th class="px-6 py-4 text-[14px] font-bold uppercase tracking-wide">Key Features</th>
                  <th class="px-6 py-4 text-[14px] font-bold uppercase tracking-wide">Customer Assurance</th>
                  <th class="px-6 py-4 text-[14px] font-bold uppercase tracking-wide">Professional Commitment</th>
                </tr>
              </thead>
              <tbody>
                {service.seoContent.transparencySection.tableRows.map((row, i) => (
                  <tr class={i % 2 === 0 ? "bg-white" : "bg-[#f8f9fa]"}>
                    <td class="px-6 py-4 text-[15px] font-semibold text-[#151d25]">{row.service}</td>
                    <td class="px-6 py-4 text-[15px] text-[#567798]">{row.features}</td>
                    <td class="px-6 py-4 text-[15px] text-[#567798]">{row.assurance}</td>
                    <td class="px-6 py-4 text-[15px] text-[#567798]">{row.commitment}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="text-[#567798] text-[13px] italic mt-3">Our dedication to transparency and professionalism across all drywall services and customer-focused approach.</p>
        </div>
      </section>

      {/* Why Expert Repair Goes Beyond Handyman */}
      <section class="bg-[#f0f2f4] section-padding">
        <div class="site-container">
          <p class="section-label">Expert Difference</p>
          <h2 class="section-heading mb-6">{service.seoContent.expertiseSection.heading}</h2>
          <div class="accent-divider"></div>
          <p class="text-[#151d25] text-[17px] leading-relaxed mt-6 max-w-[760px]">{service.seoContent.expertiseSection.body}</p>
        </div>
      </section>
    </>
  )}

  <!-- ── FAQ ──────────────────────────────────────────────────── -->
  <section class="bg-white section-padding">>
    <div class="site-container">
      <div class="max-w-[760px] mx-auto">
        <div class="text-center section-header">
          <p class="section-label">Common Questions</p>
          <h2 class="section-heading">Frequently Asked Questions</h2>
          <div class="accent-divider-center"></div>
        </div>

        <div class="flex flex-col divide-y divide-[#cdd8e3]">
          {service.faqs.map(({ q, a }, i) => (
            <div class="faq-item py-6">
              <button
                class="w-full flex items-center justify-between gap-5 text-left"
                aria-expanded="false"
                data-faq={i}
              >
                <span class="text-[#151d25] text-[16px] font-semibold leading-snug">{q}</span>
                <svg
                  class="faq-icon shrink-0 text-[#2c3e50] transition-transform duration-200"
                  width="20" height="20" viewBox="0 0 24 24" fill="none"
                >
                  <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </button>
              <div class="faq-answer hidden mt-4">
                <p class="text-[#567798] text-[15px] leading-relaxed">{a}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Service Area + CTA ─────────────────────────────────────────────── -->
  <section class="bg-[#2c3e50] section-padding-sm">
    <div class="site-container">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-10 text-center lg:text-left">
        <div>
          <h2 class="text-white text-[28px] lg:text-[34px] font-black tracking-tight mb-4">
            Serving the {PRIMARY_CITY}, {PRIMARY_STATE} Area
          </h2>
          <div class="flex flex-wrap gap-2 justify-center lg:justify-start">
            {["McKinney", "Allen", "Frisco", "Plano", "Prosper", "Celina"].map((city) => (
              <span class={`px-4 py-2 rounded-full text-[13px] font-semibold ${city === PRIMARY_CITY ? "bg-[#b05d45] text-white" : "bg-white/10 text-white/75"}`}>
                {city}
              </span>
            ))}
          </div>
        </div>
        <a href={telHref} class="btn-primary shrink-0">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.13 6.13l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.73 2.03z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Call Now {PHONE_DISPLAY}
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  document.querySelectorAll(".faq-item button").forEach((btn) => {
    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", String(!expanded));
      const answer = btn.nextElementSibling as HTMLElement;
      const icon   = btn.querySelector(".faq-icon") as SVGElement;
      answer?.classList.toggle("hidden", expanded);
      if (icon) icon.style.transform = expanded ? "" : "rotate(45deg)";
    });
  });
</script>
