---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import {
  BUSINESS_NAME,
  PHONE_DISPLAY,
  PHONE_RAW,
  EMAIL,
  ADDRESS_STREET,
  ADDRESS_CITY,
  ADDRESS_STATE,
  ADDRESS_ZIP,
  PRIMARY_CITY,
  PRIMARY_STATE,
  SITE_URL,
} from "@/config/site";

const telHref = `tel:${PHONE_RAW}`;
const mailHref = `mailto:${EMAIL}`;

const lastUpdated = "March 1, 2025";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE_URL}/` },
    { "@type": "ListItem", "position": 2, "name": "Terms of Service", "item": `${SITE_URL}/terms-of-service` }
  ]
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": `Terms of Service | ${BUSINESS_NAME}`,
  "url": `${SITE_URL}/terms-of-service`,
  "description": `Terms of service for ${BUSINESS_NAME}. Governs use of our website and scheduling of handyman services in ${PRIMARY_CITY}, ${PRIMARY_STATE} and surrounding communities.`
};
---

<Layout
  title={`Terms of Service | ${BUSINESS_NAME}`}
  description={`Terms of service for ${BUSINESS_NAME}. Governs use of our website and scheduling of handyman services in ${PRIMARY_CITY}, ${PRIMARY_STATE} and surrounding communities.`}
  schema={[breadcrumbSchema, webPageSchema]}
>
  <Header />

  <section class="bg-[#1b2a46] py-20 lg:py-24">
    <div class="site-container">
      <div class="flex items-center gap-2 text-[13px] text-white/70 mb-6">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white/90">Terms of Service</span>
      </div>
      <p class="section-label">Legal</p>
      <h1 class="text-white font-black tracking-tight leading-[1.05] mb-3" style="font-size: clamp(2rem, 3.5vw, 3rem);">Terms of Service</h1>
      <p class="text-white/80 text-[14px]">Last updated: {lastUpdated}</p>
    </div>
  </section>

  <section class="bg-white section-padding">
    <div class="site-container">
      <div class="max-w-[800px] mx-auto">
      <div class="text-[15px] leading-[1.8] text-[#475569] flex flex-col gap-0">

        <p class="mb-6">By using our website or scheduling services with {BUSINESS_NAME}, you agree to these terms. Please read them carefully.</p>

        <h2 class="text-[#0f172a] text-[22px] font-bold mt-8 mb-4">1. Services</h2>
        <p>{BUSINESS_NAME} provides residential handyman and home repair services in the {PRIMARY_CITY}, {PRIMARY_STATE} area and surrounding communities. The specific scope of work for each job is agreed upon before service begins and outlined in your service agreement or quote.</p>

        <h2 class="text-[#0f172a] text-[22px] font-bold mt-8 mb-4">2. Scheduling and Cancellations</h2>
        <ul class="list-disc pl-6 flex flex-col gap-2 my-4">
          <li>Appointments are confirmed by phone or email. We ask that you confirm receipt of your appointment confirmation.</li>
          <li>Please provide at least <strong>24 hours notice</strong> if you need to cancel or reschedule.</li>
          <li>Late cancellations (less than 24 hours) or no-shows may be subject to a cancellation fee of up to $50.</li>
          <li>We reserve the right to reschedule appointments due to weather, emergencies, or technician availability. We will notify you as soon as possible in such cases.</li>
        </ul>

        <h2 class="text-[#0f172a] text-[22px] font-bold mt-8 mb-4">3. Pricing and Payment</h2>
        <ul class="list-disc pl-6 flex flex-col gap-2 my-4">
          <li>All pricing is provided upfront before work begins. We do not start work without your approval of the quoted price.</li>
          <li>If the scope of work changes during the job, we will discuss any additional costs with you before proceeding.</li>
          <li>Payment is due upon completion of services unless otherwise arranged in writing.</li>
          <li>We accept cash, check, major credit cards, Venmo, and Zelle.</li>
          <li>Returned checks are subject to a $35 returned check fee.</li>
        </ul>

        <h2 class="text-[#0f172a] text-[22px] font-bold mt-8 mb-4">4. Access to Property</h2>
        <p>By scheduling a service, you authorize {BUSINESS_NAME} and its technicians to access the agreed areas of your property for the purpose of performing the requested services. Please ensure a responsible adult (18+) is present during the service.</p>

        <h2 class="text-[#0f172a] text-[22px] font-bold mt-8 mb-4">5. Warranty and Satisfaction Guarantee</h2>
        <ul class="list-disc pl-6 flex flex-col gap-2 my-4">
          <li>We stand behind our work. If you are not satisfied with a completed job, notify us within <strong>7 days</strong> and we will return to address the issue at no additional charge.</li>
          <li>Our warranty covers workmanship only, not materials provided by the customer or pre-existing conditions.</li>
          <li>Warranty does not cover damage caused by misuse, accidents, or normal wear and tear after completion.</li>
        </ul>

        <h2 class="text-[#0f172a] text-[22px] font-bold mt-8 mb-4">6. Limitation of Liability</h2>
        <p>{BUSINESS_NAME} carries full general liability insurance. In the event of property damage caused by our negligence during service, our liability is limited to the cost of repair or replacement of the damaged item, not to exceed the total amount paid for the service in question.</p>
        <p class="mt-3">We are not liable for pre-existing conditions, damage caused by third parties, or consequential damages.</p>

        <h2 class="text-[#0f172a] text-[22px] font-bold mt-8 mb-4">7. Hazardous Conditions</h2>
        <p>Our technicians reserve the right to decline or stop work if they encounter hazardous conditions, including but not limited to: asbestos, mold, structural instability, or unsafe electrical situations beyond the scope of handyman services. In such cases, we will advise you on appropriate next steps.</p>

        <h2 class="text-[#0f172a] text-[22px] font-bold mt-8 mb-4">8. Website Use</h2>
        <p>The content on our website is for informational purposes only. We make no warranties regarding the accuracy or completeness of the information provided. Use of our website is at your own risk.</p>

        <h2 class="text-[#0f172a] text-[22px] font-bold mt-8 mb-4">9. Governing Law</h2>
        <p>These terms are governed by the laws of the State of Texas. Any disputes shall be resolved in the courts of Collin County, Texas.</p>

        <h2 class="text-[#0f172a] text-[22px] font-bold mt-8 mb-4">10. Changes to These Terms</h2>
        <p>We may update these terms from time to time. Continued use of our services after changes constitutes acceptance of the updated terms.</p>

        <h2 class="text-[#0f172a] text-[22px] font-bold mt-8 mb-4">11. Contact</h2>
        <div class="bg-[#f8fafc] rounded-xl border border-[#e2e8f0] p-5 mt-2">
          <p class="font-semibold text-[#0f172a]">{BUSINESS_NAME}</p>
          <p>{ADDRESS_STREET}, {ADDRESS_CITY}, {ADDRESS_STATE} {ADDRESS_ZIP}</p>
          <p><a href={telHref} class="text-[#c8622a] hover:underline">{PHONE_DISPLAY}</a></p>
          <p><a href={mailHref} class="text-[#c8622a] hover:underline">{EMAIL}</a></p>
        </div>
      </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
