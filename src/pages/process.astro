---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import {
  BUSINESS_NAME,
  PHONE_DISPLAY,
  PHONE_RAW,
  SITE_URL,
  RESPONSE_TIME,
} from "@/config/site";

const telHref = `tel:${PHONE_RAW}`;

const steps = [
  {
    num: "01",
    title: "The Call (or Click)",
    desc: `Tell us what you need — use our online form, call us at ${PHONE_DISPLAY}, or send a text. Describe the repair and snap a few photos if you have them. We typically respond within ${RESPONSE_TIME}.`,
    detail: "No job is too small. From a single screw to an entire room, we respond to every inquiry with the same professionalism.",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.13 6.13l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.73 2.03z" stroke="#b05d45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    num: "02",
    title: "The Dispatch & Quote",
    desc: "Before we set a foot in your home, you'll have a clear, itemized quote. We don't do 'it depends' pricing. You'll know exactly what you're paying for each item on your list — then we schedule a time that works for you.",
    detail: "Our pricing is straightforward: labor per task, materials at cost. We'll never upsell you or discover 'surprise' add-ons once we arrive.",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><line x1="12" y1="1" x2="12" y2="23" stroke="#b05d45" stroke-width="2" stroke-linecap="round"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" stroke="#b05d45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    num: "03",
    title: "The Execution",
    desc: "Your technician arrives in uniform with all the tools and materials needed for your job. We protect your floors and work areas before we start, and work efficiently to minimize disruption to your day.",
    detail: "All technicians are background-checked, insured, and trained. We work with the same care we'd give our own homes.",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" stroke="#b05d45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    num: "04",
    title: "The Clean-Up & Walkthrough",
    desc: "When the work is done, we clean up completely — dust, debris, packaging, and any leftover materials. We walk you through every completed item before we leave and answer any questions.",
    detail: "Your home should look better than when we arrived — not just in the area we worked, but everywhere.",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="#b05d45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><polyline points="9 22 9 12 15 12 15 22" stroke="#b05d45" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE_URL}/` },
    { "@type": "ListItem", "position": 2, "name": "Our Process", "item": `${SITE_URL}/process` }
  ]
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": `Our Process | ${BUSINESS_NAME}`,
  "url": `${SITE_URL}/process`,
  "description": `How ${BUSINESS_NAME} works — from quote to cleanup. Transparent pricing, expert repairs, and a clean home every time.`
};
---

<Layout
  title={`Our Process | ${BUSINESS_NAME} — Simple, Transparent, Reliable`}
  description={`How ${BUSINESS_NAME} works — from quote to cleanup. Transparent pricing, expert repairs, and a clean home every time. Call ${PHONE_DISPLAY}.`}
  schema={[breadcrumbSchema, webPageSchema]}
>
  <Header />

  <!-- ── Photo Hero ─────────────────────────────────────────────────────── -->
  <section class="relative min-h-[440px] lg:min-h-[520px] flex items-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="/truck-image.webp"
        alt={`${BUSINESS_NAME} service truck — reliable, professional handyman service`}
        class="w-full h-full object-cover object-[55%_top]"
        srcset="/truck-image-400w.webp 400w, /truck-image-640w.webp 640w, /truck-image-800w.webp 800w, /truck-image-1024w.webp 1024w, /truck-image-1456w.webp 1456w, /truck-image.webp 2048w"
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
        width="1456"
        height="600"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-[#151d25]/95 via-[#151d25]/80 to-[#151d25]/35"></div>
    </div>
    <div class="relative z-10 w-full site-container py-20 lg:py-28">
      <!-- Breadcrumb -->
      <div class="flex items-center gap-2 text-[13px] text-white/70 mb-6">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white/90">Our Process</span>
      </div>
      <p class="section-label">How It Works</p>
      <h1 class="text-white font-black tracking-tight leading-[1.05] mb-5 max-w-[640px]" style="font-size: clamp(2.25rem, 4vw, 3.5rem);">
        Simple. Transparent.<br/>Reliable.
      </h1>
      <p class="text-white/90 text-[17px] max-w-[520px] leading-relaxed">
        From first contact to final walkthrough — here's exactly what to expect when you work with {BUSINESS_NAME}.
      </p>
    </div>
  </section>

  <!-- ── Process Steps (Timeline) ──────────────────────────────────────── -->
  <section class="bg-white section-padding">
    <div class="site-container">

      <div class="text-center section-header reveal-item">
        <p class="section-label">Step by Step</p>
        <h2 class="section-heading">From First Call to Clean Home</h2>
        <div class="accent-divider-center"></div>
        <p class="text-[#567798] text-[17px] mt-2 max-w-[480px] mx-auto leading-relaxed">
          Four simple steps. No surprises. No mess. Just results.
        </p>
      </div>

      <!-- Timeline layout -->
      <div class="max-w-[800px] mx-auto">
        {steps.map(({ num, title, desc, detail, icon }, i) => (
          <div class={`flex gap-8 lg:gap-12 reveal-item ${i < steps.length - 1 ? "pb-12 mb-0" : ""}`}>
            <!-- Step marker -->
            <div class="flex flex-col items-center shrink-0">
              <div class="w-16 h-16 rounded-full bg-[#2c3e50] border-4 border-[#b05d45]/30 flex items-center justify-center shadow-xl z-10">
                <Fragment set:html={icon} />
              </div>
              {i < steps.length - 1 && (
                <div class="w-px flex-1 bg-gradient-to-b from-[#b05d45]/40 to-[#e2e8f0] mt-3 min-h-[80px]"></div>
              )}
            </div>
            <!-- Content -->
            <div class="pt-2 pb-4 flex-1">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-[#b05d45] text-[12px] font-black uppercase tracking-widest">Step {num}</span>
              </div>
              <h2 class="text-[#151d25] text-[22px] lg:text-[26px] font-black tracking-tight mb-3">{title}</h2>
              <p class="text-[#567798] text-[16px] leading-relaxed mb-4">{desc}</p>
              <div class="flex items-start gap-3 bg-[#f0f2f4] rounded-xl px-5 py-4 border border-[#cdd8e3]">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="mt-0.5 shrink-0 text-[#b05d45]">
                  <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                  <path d="M12 16v-4M12 8h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
                <p class="text-[#567798] text-[14px] leading-relaxed">{detail}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Promise Section ────────────────────────────────────────────────── -->
  <section class="bg-[#f0f2f4] section-padding">
    <div class="site-container">
      <div class="max-w-[760px] mx-auto text-center reveal-item">
        <p class="section-label">Our Commitment</p>
        <h2 class="section-heading mb-4">Our Promise to You</h2>
        <div class="accent-divider-center"></div>
        <p class="text-[#567798] text-[17px] leading-relaxed mb-10 max-w-[600px] mx-auto">
          We know there are a lot of handyman services out there. What sets us apart isn't just the quality of the work — it's the experience of working with us. We answer the phone. We show up on time. We price honestly. And we don't leave until you're satisfied.
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          {["Fully Insured", "Background Checked", "On Time Guarantee", "Transparent Pricing", "Free Estimates", "Satisfaction Guarantee"].map((b) => (
            <span class="pill-chip">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <polyline points="20 6 9 17 4 12" stroke="#b05d45" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {b}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA Banner ─────────────────────────────────────────────────────── -->
  <section class="bg-[#b05d45] section-padding-sm">
    <div class="site-container flex flex-col md:flex-row items-center justify-between gap-6 text-center md:text-left reveal-item">
      <div>
        <h2 class="text-white font-black text-[28px] lg:text-[36px] tracking-tight leading-tight">
          Ready to get started?
        </h2>
        <p class="text-white/80 text-[16px] mt-2">Step one takes about 2 minutes.</p>
      </div>
      <a href={telHref} class="btn-navy shrink-0">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.13 6.13l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.73 2.03z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Call Now {PHONE_DISPLAY}
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
  );
  document.querySelectorAll(".reveal-item").forEach((el) => observer.observe(el));
</script>
