---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import {
  BUSINESS_NAME,
  BUSINESS_TAGLINE,
  BUSINESS_EST,
  PHONE_DISPLAY,
  PHONE_RAW,
  SITE_URL,
  REVIEW_COUNT,
  YEARS_EXPERIENCE,
  JOBS_COMPLETED,
  PRIMARY_CITY,
  PRIMARY_STATE,
  SEO_DEFAULT_DESC,
} from "@/config/site";

const telHref = `tel:${PHONE_RAW}`;

const stats = [
  { value: REVIEW_COUNT, label: "5-Star Reviews" },
  { value: JOBS_COMPLETED, label: "Jobs Completed" },
  { value: YEARS_EXPERIENCE, label: `Years in ${PRIMARY_CITY}` },
  { value: "100%", label: "Satisfaction Rate" },
];

const values = [
  { title: "Transparent Pricing",  desc: "You know the full cost before we pick up a tool. No surprise invoices.", icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>` },
  { title: "Respect for Your Home", desc: "We wear shoe covers, protect your floors, and clean up completely every time.", icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><polyline points="9 22 9 12 15 12 15 22" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>` },
  { title: "Background Checked",   desc: "Every technician undergoes a thorough background check before entering your home.", icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>` },
  { title: "On Time, Every Time",  desc: "We show up when we say we will. If something changes, we call ahead.", icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="white" stroke-width="2"/><path d="M12 6v6l4 2" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>` },
  { title: "Fully Insured",        desc: "We carry full liability insurance. Your home is protected if anything goes wrong.", icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><polyline points="20 6 9 17 4 12" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>` },
  { title: "Satisfaction Guaranteed", desc: "If you're not happy with the work, we'll come back and make it right.", icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3H14z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>` },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${SITE_URL}/` },
    { "@type": "ListItem", "position": 2, "name": "About Us", "item": `${SITE_URL}/about` }
  ]
};

const aboutPageSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": `About ${BUSINESS_NAME}`,
  "url": `${SITE_URL}/about`,
  "mainEntity": { "@id": `${SITE_URL}/#business` }
};
---

<Layout
  title={`About Us | ${BUSINESS_NAME} — Trusted Local Handyman Since ${BUSINESS_EST}`}
  description={`${BUSINESS_NAME} — your trusted local handyman team in ${PRIMARY_CITY}, ${PRIMARY_STATE} since ${BUSINESS_EST}. Licensed, insured, background-checked, and committed to quality. Learn our story.`}
  schema={[breadcrumbSchema, aboutPageSchema]}
>
  <Header />

  <!-- ── Photo Hero ─────────────────────────────────────────────────────── -->
  <section class="relative min-h-[440px] lg:min-h-[520px] flex items-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="/shop-door.webp"
        alt={`${BUSINESS_NAME} owner in front of branded shop door`}
        class="w-full h-full object-cover object-[55%_top]"
        srcset="/caleb-shop-door-400w.webp 400w, /caleb-shop-door-640w.webp 640w, /caleb-shop-door-800w.webp 800w, /caleb-shop-door-1024w.webp 1024w, /caleb-shop-door-1456w.webp 1456w, /about-caleb-truck.webp 2048w"
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
        width="1456"
        height="600"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-[#151d25]/95 via-[#151d25]/75 to-[#151d25]/30"></div>
    </div>
    <div class="relative z-10 w-full site-container py-20 lg:py-28">
      <!-- Breadcrumb -->
      <div class="flex items-center gap-2 text-[13px] text-white/70 mb-6">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white/90">About Us</span>
      </div>
      <p class="section-label">Our Story</p>
      <h1 class="text-white font-black tracking-tight leading-[1.05] mb-5 max-w-[620px]" style="font-size: clamp(2.25rem, 4vw, 3.5rem);">
        {BUSINESS_TAGLINE}
      </h1>
      <p class="text-white/90 text-[17px] max-w-[520px] leading-relaxed">
        Built on a simple idea: homeowners deserve a handyman service they can actually trust. One that shows up on time, prices honestly, and does the work right.
      </p>
    </div>
  </section>

  <!-- ── Stats Bar ──────────────────────────────────────────────────────── -->
  <section class="bg-[#2c3e50] section-padding-sm">
    <div class="site-container">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 text-center">
        {stats.map(({ value, label }) => (
          <div class="reveal-item">
            <div class="text-[#e2a03f] font-black leading-none mb-2" style="font-size: clamp(2.25rem, 4vw, 3rem);">{value}</div>
            <div class="text-white/80 text-[12px] font-semibold uppercase tracking-widest">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Story + Photo ──────────────────────────────────────────────────── -->
  <section class="bg-white section-padding">
    <div class="site-container">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">

        <!-- Copy -->
        <div class="reveal-item">
          <p class="section-label">Est. 2008</p>
          <h2 class="section-heading mb-2">Why We Started</h2>
          <div class="accent-divider mb-6"></div>
          <div class="flex flex-col gap-5 text-[#567798] text-[17px] leading-relaxed">
            <p>Like most homeowners, our founder had been burned by unreliable contractors — guys who didn't show up, gave vague pricing, or left a mess behind. After years of dealing with that, the decision was simple: build the service that every homeowner actually wants.</p>
            <p>We started in McKinney because this is our home. Our team lives here, sends their kids to school here, and cares deeply about the community. Every job we take on is a neighbor's home — and we treat it that way.</p>
            <p>Today, {BUSINESS_NAME} has completed over {JOBS_COMPLETED} projects for homeowners across {PRIMARY_CITY}, Allen, Frisco, Prosper, and Celina. We've built our reputation one job at a time — and we're just getting started.</p>
          </div>
          <div class="mt-8 flex flex-col gap-4">
            {[
              "Fully Insured & Background Checked",
              `Established ${BUSINESS_EST} — ${YEARS_EXPERIENCE} Years Experience`,
              `${REVIEW_COUNT} Verified 5-Star Reviews`,
              "Free Estimates, No Obligation",
            ].map((item) => (
              <div class="flex items-center gap-3 text-[16px] text-[#151d25]">
                <div class="w-6 h-6 rounded-full bg-[#b05d45]/10 flex items-center justify-center shrink-0">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
                    <polyline points="20 6 9 17 4 12" stroke="#b05d45" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <span class="font-medium">{item}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Photo -->
        <div class="reveal-item">
          <div class="rounded-2xl overflow-hidden shadow-2xl">
            <img
              src="/about-caleb-truck.webp"
              alt={`${BUSINESS_NAME} owner standing with branded service truck`}
              class="w-full h-auto object-cover"
              loading="lazy" decoding="async"
              width="700"
              height="560"
            />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Values Grid ────────────────────────────────────────────────────── -->
  <section class="bg-[#f0f2f4] section-padding">
    <div class="site-container">
      <div class="text-center section-header reveal-item">
        <p class="section-label">What We Stand For</p>
        <h2 class="section-heading">Our Core Values</h2>
        <div class="accent-divider-center"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {values.map(({ title, desc, icon }) => (
          <div class="bg-white rounded-2xl p-8 border border-[#cdd8e3] hover:shadow-xl hover:border-[#2c3e50] transition-all duration-300 reveal-item">
            <div class="w-14 h-14 bg-[#2c3e50] rounded-2xl flex items-center justify-center mb-5 shadow-md">
              <Fragment set:html={icon} />
            </div>
            <h3 class="text-[#151d25] text-[18px] font-bold mb-3">{title}</h3>
            <p class="text-[#567798] text-[15px] leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CTA Band ───────────────────────────────────────────────────────── -->
  <section class="bg-[#b05d45] section-padding-sm">
    <div class="site-container">
      <div class="flex flex-col md:flex-row items-center justify-between gap-8 text-center md:text-left">
        <div class="max-w-[520px]">
          <h2 class="text-white text-[28px] lg:text-[36px] font-black tracking-tight mb-3">
            Experience the difference.
          </h2>
          <p class="text-white/80 text-[17px] leading-relaxed">
            Free estimates. Same-week availability. {REVIEW_COUNT} 5-star reviews.
          </p>
        </div>
        <a href={telHref} class="btn-navy shrink-0">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.13 6.13l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.73 2.03z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Call Now {PHONE_DISPLAY}
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
  );
  document.querySelectorAll(".reveal-item").forEach((el) => observer.observe(el));
</script>
