---
import Layout from "../layouts/Layout.astro";
import { createAdminClient } from "../lib/supabase";
import { BUSINESS_NAME } from "../config/site";

// Fetch press-kit bucket file list at request time (SSR)
let assets: Array<{ name: string; id: string }> = [];
let fetchError = false;

try {
  const supabase = createAdminClient();
  const { data, error } = await supabase.storage
    .from("press-kit")
    .list("", { limit: 100, sortBy: { column: "name", order: "asc" } });

  if (error) throw error;
  assets = data ?? [];
} catch (err) {
  console.error("[media-kit] Failed to list press-kit bucket:", err);
  fetchError = true;
}

// Build public URLs for each asset
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL as string;
const assetUrls = assets.map((a) => ({
  name:        a.name,
  url:         `${supabaseUrl}/storage/v1/object/public/press-kit/${a.name}`,
  ext:         a.name.split(".").pop()?.toUpperCase() ?? "FILE",
  isImage:     /\.(jpg|jpeg|png|webp|svg)$/i.test(a.name),
}));
---

<Layout
  title={`Media Kit | ${BUSINESS_NAME}`}
  description={`Download ${BUSINESS_NAME} logos, photos, and brand assets.`}
>
  <section class="section-padding bg-snow">
    <div class="site-container-narrow">
      <span class="section-label">Press & Media</span>
      <h1 class="section-heading reveal-up">Media Kit</h1>
      <div class="accent-divider" />
      <p class="section-subheading reveal-up">
        Download logos, brand assets, and approved photos for press and partner use.
        For usage questions contact <a href={`mailto:{{CLIENT_EMAIL}}`} class="underline">{{CLIENT_EMAIL}}</a>.
      </p>

      {fetchError && (
        <p class="mt-8 text-muted">
          Media assets are being prepared. Check back shortly or contact us directly.
        </p>
      )}

      {!fetchError && assetUrls.length === 0 && (
        <p class="mt-8 text-muted">
          No assets available yet. Please check back shortly.
        </p>
      )}

      {assetUrls.length > 0 && (
        <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 gap-6">
          {assetUrls.map((asset) => (
            <a
              href={asset.url}
              download
              target="_blank"
              rel="noopener noreferrer"
              class="reveal-up flex items-center gap-4 p-5 bg-white border border-border rounded-xl hover:shadow-md transition-shadow"
            >
              {asset.isImage ? (
                <img
                  src={asset.url}
                  alt={asset.name}
                  width="64"
                  height="64"
                  class="rounded object-contain bg-brand-accent p-2 flex-shrink-0"
                />
              ) : (
                <div class="w-16 h-16 flex-shrink-0 flex items-center justify-center rounded bg-brand-accent font-display font-700 text-xs text-brand-primary">
                  {asset.ext}
                </div>
              )}
              <div class="min-w-0">
                <p class="font-display font-600 text-ink truncate">{asset.name}</p>
                <p class="text-xs text-muted mt-0.5">Click to download</p>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);
  document.querySelectorAll<HTMLElement>(".reveal-up").forEach((el) => {
    gsap.fromTo(el, { opacity: 0, y: 24 }, {
      opacity: 1, y: 0, duration: 0.4, ease: "power2.out",
      scrollTrigger: { trigger: el, start: "top 88%", once: true },
    });
  });
</script>
