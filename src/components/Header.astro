---
import {
  BUSINESS_NAME,
  PHONE_DISPLAY,
  PHONE_RAW,
} from "../config/site";

const navLinks = [
  { label: "Services",   href: "/services" },
  { label: "Locations",  href: "/locations" },
  { label: "Projects",   href: "/projects" },
  { label: "About Us",   href: "/about" },
  { label: "Contact Us", href: "/contact" },
];

const currentPath = Astro.url.pathname;
const telHref     = `tel:${PHONE_RAW}`;
---

<!-- WCAG: Header bg navy — white text = 9:1 ✅ -->
<header class="sticky top-0 z-50 bg-[#2c3e50] shadow-[0_2px_16px_rgba(21,29,37,0.25)]">
  <div class="site-container flex items-center justify-between h-[80px]">

    <!-- Logo — uses dark version on dark header bg -->
    <a href="/" class="flex items-center shrink-0" aria-label={`${BUSINESS_NAME} — Home`}>
      <picture>
        <source
          type="image/webp"
          srcset="/logo-horizontal-700w.webp 350w, /logo-horizontal-700w.webp 700w"
          sizes="(max-width: 640px) 160px, 200px"
        />
        <img
          src="/logo-horizontal.webp"
          alt={`${BUSINESS_NAME} — Handyman & Repairs`}
          width="200"
          height="44"
          class="site-logo"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </picture>
    </a>

    <!-- Desktop Nav — solid white text on Charcoal Blue = 9:1 WCAG ✅ -->
    <nav class="hidden lg:flex items-center gap-8" aria-label="Main navigation">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class={[
            "text-[15px] font-semibold tracking-[0.01em] transition-all duration-150 min-h-[52px] flex items-center relative",
            "after:absolute after:bottom-0 after:left-0 after:w-full after:h-[2px] after:rounded-full after:transition-transform after:duration-200 after:origin-left",
            currentPath === href || currentPath.startsWith(href + "/")
              ? "text-[#e2a03f] after:bg-[#e2a03f] after:scale-x-100"
              : "text-white hover:text-white after:bg-white after:scale-x-0 hover:after:scale-x-100",
          ].join(" ")}
          aria-current={currentPath === href ? "page" : undefined}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- CTA Phone Button — WCAG: white on clay = 4.7:1 ✅ -->
    <a
      href={telHref}
      class="hidden lg:flex items-center gap-2.5
             bg-[#b05d45] hover:bg-[#8d4a37]
             text-white font-bold text-[15px]
             px-6 py-3 rounded-full
             transition-all duration-200
             shadow-[0_4px_14px_rgba(176,93,69,0.4)] hover:shadow-[0_8px_24px_rgba(176,93,69,0.5)]
             hover:-translate-y-0.5 active:translate-y-0 active:scale-[0.97]
             shrink-0 min-h-[52px]"
      onclick="gtag && gtag('event', 'phone_click', {event_category: 'engagement', event_label: 'header_cta'})"
      aria-label={`Call ${BUSINESS_NAME} at ${PHONE_DISPLAY}`}
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.13 6.13l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.73 2.03z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      {PHONE_DISPLAY}
    </a>

    <!-- Mobile hamburger — ADA: 52×52px touch target -->
    <button
      id="mobile-menu-toggle"
      class="lg:hidden text-white p-2 rounded-lg min-h-[52px] min-w-[52px] flex items-center justify-center hover:bg-white/10 transition-colors"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg id="icon-menu" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M3 12h18M3 6h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <svg id="icon-close" class="hidden" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu — WCAG: white text on navyDark passes ✅ -->
  <nav
    id="mobile-menu"
    class="hidden lg:hidden bg-[#1a252f] border-t border-white/10"
    aria-label="Mobile navigation"
  >
    <div class="site-container py-5 flex flex-col gap-1">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class={[
            "py-3.5 px-4 rounded-xl text-[16px] font-semibold transition-colors min-h-[52px] flex items-center",
            currentPath === href || currentPath.startsWith(href + "/")
              ? "text-[#e2a03f] bg-white/5"
              : "text-white hover:text-white hover:bg-white/8",
          ].join(" ")}
          aria-current={currentPath === href ? "page" : undefined}
        >
          {label}
        </a>
      ))}
      <!-- Mobile CTA -->
      <a
        href={telHref}
        class="mt-4 flex items-center justify-center gap-2.5
               bg-[#b05d45] hover:bg-[#8d4a37]
               text-white font-bold text-[16px]
               px-5 py-4 rounded-full
               transition-all duration-200
               shadow-[0_4px_14px_rgba(176,93,69,0.4)]
               min-h-[56px]"
        onclick="gtag && gtag('event', 'phone_click', {event_category: 'engagement', event_label: 'mobile_menu_cta'})"
        aria-label={`Call ${BUSINESS_NAME} at ${PHONE_DISPLAY}`}
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.13 6.13l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.73 2.03z" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Call {PHONE_DISPLAY}
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle    = document.getElementById("mobile-menu-toggle");
  const menu      = document.getElementById("mobile-menu");
  const iconMenu  = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");

  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close navigation menu" : "Open navigation menu");
    iconMenu?.classList.toggle("hidden", open);
    iconClose?.classList.toggle("hidden", !open);
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
      toggle?.setAttribute("aria-label", "Open navigation menu");
      iconMenu?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    });
  });
</script>
