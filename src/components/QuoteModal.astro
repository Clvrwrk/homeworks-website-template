---
import { SERVICES, PHONE_RAW, PHONE_DISPLAY } from "../config/site";
const telHref = `tel:${PHONE_RAW}`;
---

<!-- Global 2-step quote modal. Triggered by any element with data-quote-modal.
     Optional data-service="slug" pre-selects that service pill on open.
     Renders once in Layout.astro — never import per-page. -->
<dialog
  id="quote-modal"
  class="fixed inset-0 z-[100] m-0 w-full h-full max-w-none max-h-none bg-transparent p-0 border-none"
  aria-labelledby="quote-modal-title"
  aria-modal="true"
>
  <!-- Backdrop -->
  <div id="quote-backdrop" class="absolute inset-0 bg-[#151d25]/70 backdrop-blur-sm"></div>

  <!-- Modal box -->
  <div class="relative z-10 flex items-center justify-center min-h-full p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-[480px] overflow-hidden">

      <!-- Header band — uses brand-secondary bg -->
      <div class="px-6 py-5 flex items-start justify-between gap-4" style="background: var(--brand-secondary);">
        <div>
          <p id="quote-modal-step-label" class="text-[11px] font-bold uppercase tracking-widest mb-1" style="color: #e2a03f;">Step 1 of 2</p>
          <h2 id="quote-modal-title" class="text-white font-black text-[22px] leading-tight" style="font-family: var(--font-display), 'Plus Jakarta Sans', sans-serif;">
            What do you need help with?
          </h2>
        </div>
        <button
          id="quote-modal-close"
          class="text-white/60 hover:text-white transition-colors mt-1 shrink-0 min-w-[32px] min-h-[32px] flex items-center justify-center rounded-lg hover:bg-white/10"
          aria-label="Close quote form"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M18 6 6 18M6 6l12 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      <!-- Step 1: Service selection -->
      <div id="quote-step-1" class="p-6">
        <p class="text-[#567798] text-[14px] mb-4">Select all that apply — we'll tailor our quote.</p>
        <div id="service-pills" class="grid grid-cols-2 gap-2 mb-6">
          {SERVICES.map((s) => (
            <button
              type="button"
              data-service-slug={s.slug}
              class="service-pill text-left px-3 py-2.5 rounded-xl border-2 border-[#dde3eb] bg-[#f8f7f6] text-[13px] font-semibold text-[#151d25] transition-all duration-150 hover:border-[color:var(--brand-primary)] hover:bg-[#fef3ec]"
            >
              {s.name}
            </button>
          ))}
        </div>
        <p id="quote-no-service-msg" class="hidden text-[13px] mb-3" style="color: var(--brand-primary);">Please select at least one service to continue.</p>
        <button
          id="quote-next-btn"
          type="button"
          class="w-full text-white font-bold text-[15px] px-6 py-3.5 rounded-xl transition-all duration-200"
          style="background: var(--brand-secondary);"
        >
          Next →
        </button>
      </div>

      <!-- Step 2: Contact info -->
      <div id="quote-step-2" class="p-6 hidden">
        <form id="quote-form" novalidate>
          <div class="mb-4">
            <label for="quote-name" class="block text-[12px] font-bold text-[#567798] uppercase tracking-wider mb-1.5">Your Name</label>
            <input
              id="quote-name"
              name="name"
              type="text"
              autocomplete="name"
              placeholder="First and last name"
              class="w-full px-4 py-3 rounded-xl border-2 border-[#dde3eb] bg-[#f8f7f6] text-[15px] text-[#151d25] focus:outline-none focus:border-[color:var(--brand-primary)] transition-colors"
            />
          </div>
          <div class="mb-6">
            <label for="quote-phone" class="block text-[12px] font-bold text-[#567798] uppercase tracking-wider mb-1.5">
              Best Phone Number <span class="text-red-500 ml-0.5" aria-hidden="true">*</span>
            </label>
            <input
              id="quote-phone"
              name="phone"
              type="tel"
              inputmode="tel"
              autocomplete="tel"
              placeholder="(555) 555-5555"
              required
              class="w-full px-4 py-3 rounded-xl border-2 border-[#dde3eb] bg-[#f8f7f6] text-[15px] text-[#151d25] focus:outline-none focus:border-[color:var(--brand-primary)] transition-colors"
            />
          </div>

          <!-- Hidden: selected services injected by JS before submit -->
          <div id="quote-services-hidden"></div>

          <p id="quote-error-msg" class="hidden text-[13px] mb-3 text-red-600"></p>

          <button
            id="quote-submit-btn"
            type="submit"
            class="w-full text-white font-bold text-[16px] px-6 py-4 rounded-xl transition-all duration-200 shadow-lg"
            style="background: var(--brand-primary);"
          >
            Get My Free Quote
          </button>
        </form>

        <button id="quote-back-btn" type="button" class="mt-4 w-full text-center text-[13px] text-[#567798] hover:text-[#151d25] transition-colors">
          ← Back
        </button>
      </div>

      <!-- Success state -->
      <div id="quote-success" class="p-8 text-center hidden">
        <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4" style="background: color-mix(in srgb, var(--brand-primary) 15%, white);">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <polyline points="20 6 9 17 4 12" stroke="var(--brand-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="font-black text-[20px] text-[#151d25] mb-2" style="font-family: var(--font-display), sans-serif;">You're all set!</h3>
        <p class="text-[#567798] text-[14px] mb-6">We'll call you within 2 hours — you can close this.</p>
        <p class="text-[13px] text-[#567798]">
          Or call us now: <a href={telHref} class="font-bold text-[#151d25] hover:underline">{PHONE_DISPLAY}</a>
        </p>
      </div>

    </div>
  </div>
</dialog>

<style>
  /* When a service pill is selected */
  .service-pill.selected-pill {
    border-color: var(--brand-primary);
    background: color-mix(in srgb, var(--brand-primary) 10%, white);
    color: var(--brand-primary);
  }
  /* Native dialog reset — make it fill viewport */
  #quote-modal[open] {
    display: flex;
    flex-direction: column;
  }
  #quote-modal::backdrop {
    display: none; /* we use our own backdrop div */
  }
</style>

<script>
  (function () {
    const modal       = document.getElementById("quote-modal") as HTMLDialogElement | null;
    const backdrop    = document.getElementById("quote-backdrop");
    const closeBtn    = document.getElementById("quote-modal-close");
    const step1       = document.getElementById("quote-step-1");
    const step2       = document.getElementById("quote-step-2");
    const successDiv  = document.getElementById("quote-success");
    const nextBtn     = document.getElementById("quote-next-btn");
    const backBtn     = document.getElementById("quote-back-btn");
    const form        = document.getElementById("quote-form") as HTMLFormElement | null;
    const submitBtn   = document.getElementById("quote-submit-btn") as HTMLButtonElement | null;
    const errorMsg    = document.getElementById("quote-error-msg");
    const noSvcMsg    = document.getElementById("quote-no-service-msg");
    const stepLabel   = document.getElementById("quote-modal-step-label");
    const modalTitle  = document.getElementById("quote-modal-title");
    const hiddenSvcs  = document.getElementById("quote-services-hidden");
    const nameInput   = document.getElementById("quote-name") as HTMLInputElement | null;

    if (!modal) return;

    function openModal(serviceSlug?: string) {
      showStep(1);
      if (serviceSlug) {
        document.querySelectorAll<HTMLButtonElement>(".service-pill").forEach((btn) => {
          if (btn.dataset.serviceSlug === serviceSlug) {
            btn.classList.add("selected-pill");
          } else {
            btn.classList.remove("selected-pill");
          }
        });
      } else {
        document.querySelectorAll<HTMLButtonElement>(".service-pill").forEach((btn) => {
          btn.classList.remove("selected-pill");
        });
      }
      noSvcMsg?.classList.add("hidden");
      if (errorMsg) { errorMsg.classList.add("hidden"); errorMsg.textContent = ""; }
      modal.showModal();
    }

    function closeModal() {
      modal.close();
    }

    function showStep(n: 1 | 2) {
      step1?.classList.toggle("hidden", n !== 1);
      step2?.classList.toggle("hidden", n !== 2);
      successDiv?.classList.add("hidden");
      if (stepLabel) stepLabel.textContent = `Step ${n} of 2`;
      if (modalTitle) {
        modalTitle.textContent = n === 1
          ? "What do you need help with?"
          : "How do we reach you?";
      }
    }

    // Delegate — any element with data-quote-modal opens the modal
    document.addEventListener("click", (e) => {
      const trigger = (e.target as Element).closest("[data-quote-modal]");
      if (!trigger) return;
      e.preventDefault();
      openModal((trigger as HTMLElement).dataset.service);
    });

    closeBtn?.addEventListener("click", closeModal);
    backdrop?.addEventListener("click", closeModal);
    modal.addEventListener("keydown", (e) => { if (e.key === "Escape") closeModal(); });

    // Service pill toggle
    document.getElementById("service-pills")?.addEventListener("click", (e) => {
      const pill = (e.target as Element).closest<HTMLButtonElement>(".service-pill");
      if (!pill) return;
      pill.classList.toggle("selected-pill");
      noSvcMsg?.classList.add("hidden");
    });

    // Next button — guard: require ≥1 service
    nextBtn?.addEventListener("click", () => {
      const selected = document.querySelectorAll(".selected-pill");
      if (selected.length === 0) {
        noSvcMsg?.classList.remove("hidden");
        return;
      }
      showStep(2);
      nameInput?.focus();
    });

    backBtn?.addEventListener("click", () => showStep(1));

    // Form submit — fetch() AJAX
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!submitBtn || !form) return;

      const phone = (document.getElementById("quote-phone") as HTMLInputElement)?.value.trim();
      if (!phone) {
        if (errorMsg) { errorMsg.textContent = "Phone number is required."; errorMsg.classList.remove("hidden"); }
        return;
      }

      // Inject hidden service inputs
      if (hiddenSvcs) {
        hiddenSvcs.innerHTML = "";
        document.querySelectorAll<HTMLButtonElement>(".selected-pill").forEach((pill) => {
          const inp = document.createElement("input");
          inp.type = "hidden";
          inp.name = "services";
          inp.value = pill.dataset.serviceSlug ?? "";
          hiddenSvcs.appendChild(inp);
        });
      }

      submitBtn.disabled = true;
      submitBtn.textContent = "Sending…";

      try {
        const fd = new FormData(form);
        const res = await fetch("/api/contact", {
          method: "POST",
          headers: { "X-Requested-With": "fetch" },
          body: fd,
        });

        if (res.ok) {
          step2?.classList.add("hidden");
          successDiv?.classList.remove("hidden");
          if (stepLabel) stepLabel.textContent = "Done!";
          if (modalTitle) modalTitle.textContent = "We've got your request!";
        } else {
          const json = await res.json().catch(() => ({}));
          if (errorMsg) {
            errorMsg.textContent = json.error === "phone_required"
              ? "Please enter your phone number."
              : "Something went wrong — please try again.";
            errorMsg.classList.remove("hidden");
          }
          submitBtn.disabled = false;
          submitBtn.textContent = "Get My Free Quote";
        }
      } catch {
        if (errorMsg) { errorMsg.textContent = "Network error — please try again."; errorMsg.classList.remove("hidden"); }
        submitBtn.disabled = false;
        submitBtn.textContent = "Get My Free Quote";
      }
    });
  })();
</script>
