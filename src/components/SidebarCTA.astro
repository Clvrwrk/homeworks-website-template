---
import { PHONE_DISPLAY, PHONE_RAW, YEARS_EXPERIENCE, JOBS_COMPLETED, RESPONSE_TIME } from "../config/site";

interface Props {
  /** Service slug — passed to data-service so QuoteModal pre-selects it. Omit on location pages. */
  service?: string;
}

const { service } = Astro.props;
const telHref = `tel:${PHONE_RAW}`;
---

<!-- Sticky sidebar — desktop only (hidden lg:block). Mobile uses bottom-nav Quote pill. -->
<aside class="hidden lg:block">
  <div class="sticky top-24 flex flex-col gap-4">

    <!-- Primary CTA — opens QuoteModal -->
    <button
      type="button"
      data-quote-modal
      data-service={service}
      class="w-full flex items-center justify-center gap-2.5
             text-white font-bold text-[16px]
             px-6 py-4 rounded-2xl
             transition-all duration-200
             hover:-translate-y-0.5 active:translate-y-0"
      style="background: var(--brand-primary); box-shadow: 0 4px 14px color-mix(in srgb, var(--brand-primary) 40%, transparent);"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <polyline points="14 2 14 8 20 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <line x1="16" y1="13" x2="8" y2="13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <line x1="16" y1="17" x2="8" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      Get a Free Quote
    </button>

    <!-- Secondary CTA — direct call -->
    <a
      href={telHref}
      class="w-full flex items-center justify-center gap-2.5
             bg-transparent border-2
             font-bold text-[15px]
             px-6 py-3.5 rounded-2xl
             transition-all duration-200"
      style="border-color: var(--brand-secondary); color: var(--brand-secondary);"
      onmouseover="this.style.background='var(--brand-secondary)'; this.style.color='white';"
      onmouseout="this.style.background='transparent'; this.style.color='var(--brand-secondary)';"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.24h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.13 6.13l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.73 2.03z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Call Now
    </a>

    <!-- Divider -->
    <div class="border-t border-[#dde3eb]"></div>

    <!-- Trust signals card -->
    <div class="bg-white rounded-2xl border border-[#dde3eb] p-5 flex flex-col gap-4">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0" style="background: color-mix(in srgb, var(--brand-primary) 12%, white);">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="var(--brand-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <p class="text-[13px] font-bold text-[#151d25] leading-tight">{YEARS_EXPERIENCE} Years Experience</p>
          <p class="text-[12px] text-[#567798]">Trusted local pros</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0" style="background: color-mix(in srgb, var(--brand-primary) 12%, white);">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <polyline points="20 6 9 17 4 12" stroke="var(--brand-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <p class="text-[13px] font-bold text-[#151d25] leading-tight">{JOBS_COMPLETED} Jobs Completed</p>
          <p class="text-[12px] text-[#567798]">Happy homeowners</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0" style="background: color-mix(in srgb, var(--brand-primary) 12%, white);">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="10" stroke="var(--brand-primary)" stroke-width="2"/>
            <polyline points="12 6 12 12 16 14" stroke="var(--brand-primary)" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
        <div>
          <p class="text-[13px] font-bold text-[#151d25] leading-tight">{RESPONSE_TIME} Response</p>
          <p class="text-[12px] text-[#567798]">We reply fast — always</p>
        </div>
      </div>
    </div>

    <!-- Small text CTA -->
    <p class="text-center text-[12px] text-[#567798]">
      Or call/text anytime:
      <a href={telHref} class="font-bold text-[#151d25] hover:underline transition-colors">{PHONE_DISPLAY}</a>
    </p>

  </div>
</aside>
