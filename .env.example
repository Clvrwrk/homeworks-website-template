# ─── GoHighLevel ──────────────────────────────────────────────────────────────
# Private Integration API Key (GHL > Settings > Integrations > Private Integrations)
GHL_API_KEY=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Location ID (GHL > Settings > Business Profile > Location ID)
GHL_LOCATION_ID=xxxxxxxxxxxxxxxx

# ─── Google Analytics 4 ───────────────────────────────────────────────────────
# Measurement ID from GA4 > Admin > Data Streams > Web Stream Details
PUBLIC_GA4_ID=G-XXXXXXXXXX

# ─── Google Search Console ────────────────────────────────────────────────────
# The `content` value from the HTML meta tag verification method in GSC
PUBLIC_GSC_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Supabase ─────────────────────────────────────────────────────────────────
# NOT required for this site — GoHighLevel handles all CRM and lead data.
# Uncomment only if a database feature is added in the future.
# PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Astro / Node ─────────────────────────────────────────────────────────────
# Port the Node SSR server listens on (used by Coolify)
PORT=4321

# Set to "production" in Coolify environment variables
NODE_ENV=production
