# ============================================================
# HOMEWORKS WEBSITE TEMPLATE — Environment Variables
# Copy to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# GoHighLevel — server-side only (NEVER use PUBLIC_ prefix)
GHL_API_KEY=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GHL_LOCATION_ID=xxxxxxxxxxxxxxxx

# Supabase
# URL is safe as PUBLIC_ (not a secret)
# service_role key is NEVER PUBLIC_ (grants full DB access)
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# Rankability — server-side only (NEVER use PUBLIC_ prefix)
RANKABILITY_API_KEY=rk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Rankability client ID (not secret — identifies this client's content)
RANKABILITY_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Google Analytics — PUBLIC_ is correct (analytics ID is not a secret)
PUBLIC_GA4_ID=G-XXXXXXXXXX
PUBLIC_GSC_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sync retry protection
RETRY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Node
PORT=4321
NODE_ENV=production
